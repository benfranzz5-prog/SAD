# ================================================================
# SETUP ORDER — follow this exactly
#
# 1. Create Neon database: Vercel dashboard → Storage → Create Database → Neon
#    Vercel injects DATABASE_URL and DATABASE_URL_UNPOOLED automatically
#
# 2. Create Blob store: Vercel dashboard → Storage → Create Store → Blob
#    Vercel injects BLOB_READ_WRITE_TOKEN automatically
#
# 3. Set manually in Vercel dashboard → Settings → Environment Variables:
#    PAYLOAD_SECRET, NEXT_PUBLIC_SERVER_URL, PAYLOAD_ADMIN_EMAIL,
#    PAYLOAD_ADMIN_PASSWORD, GTM_ID
#
# 4. For local dev: copy values from Vercel dashboard → Settings →
#    Environment Variables → Development → Download .env.local
# ================================================================

DATABASE_URL=
DATABASE_URL_UNPOOLED=
BLOB_READ_WRITE_TOKEN=
PAYLOAD_SECRET=
NEXT_PUBLIC_SERVER_URL=
PAYLOAD_ADMIN_EMAIL=
PAYLOAD_ADMIN_PASSWORD=

# Google Tag Manager
GTM_ID=    # e.g. GTM-XXXXXXX — get from tagmanager.google.com
