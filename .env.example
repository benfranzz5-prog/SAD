# Admin panel password
ADMIN_PASSWORD=your-secure-password-here

# Session signing secret (generate with: openssl rand -hex 32)
SESSION_SECRET=your-session-secret-here

# Resend API key for contact form emails
RESEND_API_KEY=re_xxxxxxxxxxxx

# GitHub integration for CMS saves (triggers Vercel redeploy)
GITHUB_TOKEN=ghp_xxxxxxxxxxxx
GITHUB_REPO=yourusername/sad-detailing
GITHUB_BRANCH=main

# Anthropic API key for admin CMS assistant
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
